# Backend API base URL.
#
# When running on a physical device, replace "localhost" with the LAN IP of
# your development machine (the machine running the backend server).
# Both your phone and your computer must be connected to the same Wi-Fi network.
#
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
#
# Copy this file to .env and fill in the value:
#   cp .env.example .env
EXPO_PUBLIC_API_URL=http://localhost:8000
