# Copy this file to .env and replace the placeholder with your computer's LAN IP.
#
# WHY THIS IS NEEDED
# ------------------
# When running Expo Go on a physical device, "localhost" resolves to the phone
# itself — not your development machine.  You must use your computer's local
# network IP address so the phone can reach the backend over Wi-Fi.
#
# Find your LAN IP:
#   macOS/Linux : ifconfig | grep "inet "
#   Windows     : ipconfig | findstr "IPv4"
#
# Then start Expo:
#   npx expo start
#
# Example:
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:8000

EXPO_PUBLIC_API_URL=http://YOUR_COMPUTER_LAN_IP:8000
