{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Expo) - Mobile",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 8081,
      "autoPort": true,
      "cwd": "vpulz_mobile"
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "py",
      "runtimeArgs": ["-m", "uvicorn", "backend.core.app:app", "--reload", "--port", "8100"],
      "port": 8100,
      "cwd": "vpulz",
      "env": {
        "PYTHONPATH": "./vpulz/backend"
      }
    }
  ]
}

